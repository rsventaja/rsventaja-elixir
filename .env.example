# Copy to .env and fill in real values. Never commit .env.

# Database: used by Docker app (DATABASE_URL) and local mix (DB_*)
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=ersventaja

# Docker app connects to postgres as "db" (service name)
DATABASE_URL=ecto://postgres:postgres@db/ersventaja

# Local mix commands (mix ecto.migrate, mix ecto.setup) — load with: set -a && source .env && set +a
DB_HOST=localhost
DB_USER=postgres
DB_PASS=postgres
DB_NAME=ersventaja

# App
PHX_HOST=localhost
SECRET_KEY_BASE=run_mix_phx.gen.secret_to_generate
CRYPTO_KEY=your_crypto_key_here

# Optional: AWS, SSL, OpenAI, etc.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SSL_KEY_PATH=
# SSL_CERT_PATH=
# OPENAI_API_KEY=
