# Copy to .env and fill in real values. Never commit .env.

# Database: used by Docker app (DATABASE_URL) and local mix (DB_*)
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=ersventaja

# Docker app connects to postgres as "db" (service name)
DATABASE_URL=ecto://postgres:postgres@db/ersventaja

# Local mix commands (mix ecto.migrate, mix ecto.setup) — load with: set -a && source .env && set +a
DB_HOST=localhost
DB_USER=postgres
DB_PASS=postgres
DB_NAME=ersventaja

# App
PHX_HOST=localhost
SECRET_KEY_BASE=run_mix_phx.gen.secret_to_generate
CRYPTO_KEY=your_crypto_key_here

# Optional: AWS, SSL, OpenAI, etc.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SSL_KEY_PATH=
# SSL_CERT_PATH=
# OPENAI_API_KEY=

# Segfy — multicálculo (api.automation) + listagem no Upfy Gate (Firebase + SSO)
# Habilita o botão "Gerar cotação Segfy" no painel de controle (default: false / desligado em prod)
# SEGFY_ENABLED=true
# SEGFY_AUTOMATION_TOKEN=
# SEGFY_AUTOMATION_BASE_URL=https://api.automation.segfy.com
# SEGFY_GESTAO_BASE_URL=https://gestao.segfy.com
# Chave `key=` do verifyPassword + login do portal Segfy
# SEGFY_FIREBASE_WEB_API_KEY=
# SEGFY_LOGIN_EMAIL=
# SEGFY_LOGIN_PASSWORD=
# 1 (padrão) = pula GET HTML legado no Gestão (302 típico); só Upfy Gate budget/list. 0 = tenta HTML antes.
# SEGFY_SKIP_GESTAO_HTML_LIST=1
# Prêmios por seguradora (HFy): Socket.IO após /calculate. 0 = desliga coleta WS.
# SEGFY_MULTICALCULO_SOCKET=1
# SEGFY_SOCKET_IO_URL=wss://socket-io.segfy.com/socket.io/?EIO=4&transport=websocket
# Opcional; padrão = SEGFY_GESTAO_BASE_URL (Origin do WS)
# SEGFY_SOCKET_IO_ORIGIN=https://gestao.segfy.com
# HAR no Windows → no WSL use /mnt/c/Users/<você>/Downloads/arquivo.har (ver docs/segfy-har-reference.md)
